OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Postgres for integration/E2E tests (packages/test/ikam-perf-report/docker-compose.yml binds port 55432)
DATABASE_URL=postgresql://narraciones:narraciones@localhost:55432/ikam_perf_report
# Embedding model for IKAM fragment embeddings.
# Default: google/embeddinggemma-300m (768d, requires HUGGINGFACE_TOKEN).
# Lightweight alternative: all-MiniLM-L6-v2 (384d, no token needed, for CI/local dev).
IKAM_EMBEDDING_MODEL=google/embeddinggemma-300m
# HuggingFace token required for google/embeddinggemma-300m access.
# Get yours at https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=

# MCP IKAM map generation endpoint (docker-compose default)
IKAM_MCP_MAP_URL=http://mcp-ikam:18081
IKAM_MCP_MAP_TIMEOUT_SECONDS=90

# Host-exposed mcp-ikam HTTP port for local debugging
IKAM_MCP_IKAM_PORT=18081
